{
  "name": "react-pipeline-runner",
  "version": "0.2.0",
  "description": "Lightweight React hook for running async actions sequentially with abort support and resume capability",
  "keywords": [
    "react",
    "hook",
    "pipeline",
    "async",
    "sequential",
    "queue",
    "runner"
  ],
  "author": "tonylus",
  "license": "ISC",
  "repository": "https://github.com/TonylusMark1/react-pipeline-runner",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.3.2",
    "@types/react": "^19.0.0",
    "happy-dom": "^20.8.4",
    "react": "^19.2.4",
    "tsup": "^8.5.1",
    "typescript": "^5.5.3",
    "vitest": "^4.1.0"
  }
}
